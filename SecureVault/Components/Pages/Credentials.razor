@page "/credentials"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using SecureVault.Data.Models
@using SecureVault.Services
@using System.Web
@attribute [Authorize]
@inject CredentialService CredentialService
@inject InputSanitizationService SanitizationService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JSRuntime
@inject ILogger<Credentials> Logger
@rendermode InteractiveServer

<PageTitle>My Credentials - SecureVault</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Stored Credentials</h2>
        <button class="btn btn-primary" @onclick="ShowAddModal">
            <span class="oi oi-plus"></span> Add New Credential
        </button>
    </div>

    @if (credentials == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (credentials.Count == 0)
    {
        <div class="alert alert-info">
            <h4 class="alert-heading">No credentials stored yet</h4>
            <p>Click "Add New Credential" to store your first credential securely.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Service Name</th>
                        <th>Username</th>
                        <th>Password</th>
                        <th>Comment</th>
                        <th>Last Updated</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var credential in credentials)
                    {
                        <tr>
                            <td>@SanitizationService.HtmlDecode(credential.ServiceName)</td>
                            <td>@SanitizationService.HtmlDecode(credential.Username)</td>
                            <td>
                                @if (revealedPasswords.Contains(credential.Id))
                                {
                                    <span class="font-monospace">@CredentialService.DecryptPassword(credential.EncryptedPassword)</span>
                                    <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="() => HidePassword(credential.Id)">
                                        Hide
                                    </button>
                                }
                                else
                                {
                                    <span>••••••••</span>
                                    <button class="btn btn-sm btn-outline-primary ms-2" @onclick="() => RevealPassword(credential.Id)">
                                        Show
                                    </button>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(credential.Comment))
                                {
                                    <span>@SanitizationService.HtmlDecode(credential.Comment)</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>@credential.UpdatedAt.ToString("g")</td>
                            <td>
                                <button class="btn btn-sm btn-warning" @onclick="() => ShowEditModal(credential)">
                                    Edit
                                </button>
                                <button class="btn btn-sm btn-danger ms-1" @onclick="() => ConfirmDelete(credential)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* Add/Edit Modal *@
@if (showModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(editingCredential == null ? "Add New Credential" : "Edit Credential")</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <EditForm Model="credentialForm" OnValidSubmit="HandleSave">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(modalErrorMessage))
                        {
                            <div class="alert alert-danger">@modalErrorMessage</div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Service Name</label>
                            <InputText @bind-Value="credentialForm.ServiceName" @onfocusout="() => credentialForm.ServiceName = SanitizationService.Trim(credentialForm.ServiceName)" class="form-control" placeholder="e.g., GitHub, Gmail, AWS" />
                            <ValidationMessage For="() => credentialForm.ServiceName" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <InputText @bind-Value="credentialForm.Username" @onfocusout="() => credentialForm.Username = SanitizationService.Trim(credentialForm.Username)" class="form-control" placeholder="username or email" />
                            <ValidationMessage For="() => credentialForm.Username" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <InputText type="password" @bind-Value="credentialForm.Password" class="form-control" placeholder="@(editingCredential == null ? "Enter password" : "Leave empty to keep current")" />
                            <ValidationMessage For="() => credentialForm.Password" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Comment (optional)</label>
                            <InputTextArea @bind-Value="credentialForm.Comment" @onfocusout="() => credentialForm.Comment = string.IsNullOrEmpty(credentialForm.Comment) ? null : SanitizationService.Trim(credentialForm.Comment)" class="form-control" rows="3" placeholder="Additional notes..." />
                            <ValidationMessage For="() => credentialForm.Comment" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@isProcessing">
                            @if (isProcessing)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Saving...</span>
                            }
                            else
                            {
                                <span>Save</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<StoredCredential>? credentials;
    private HashSet<int> revealedPasswords = new();
    private bool showModal;
    private bool isProcessing;
    private StoredCredential? editingCredential;
    private CredentialFormModel credentialForm = new();
    private string? modalErrorMessage;
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            var appUser = await UserManager.GetUserAsync(user);
            if (appUser != null)
            {
                currentUserId = appUser.Id;
                await LoadCredentials();
            }
        }
    }

    private async Task LoadCredentials()
    {
        if (currentUserId != null)
        {
            credentials = await CredentialService.GetUserCredentialsAsync(currentUserId);
        }
    }

    private void ShowAddModal()
    {
        editingCredential = null;
        credentialForm = new CredentialFormModel();
        modalErrorMessage = null;
        showModal = true;
    }

    private void ShowEditModal(StoredCredential credential)
    {
        editingCredential = credential;
        credentialForm = new CredentialFormModel
        {
            ServiceName = credential.ServiceName,
            Username = credential.Username,
            Comment = credential.Comment
        };
        modalErrorMessage = null;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        editingCredential = null;
        credentialForm = new();
        modalErrorMessage = null;
    }

    private async Task HandleSave()
    {
        if (currentUserId == null) return;

        isProcessing = true;
        modalErrorMessage = null;

        try
        {
            if (editingCredential == null)
            {
                // Create new
                await CredentialService.CreateCredentialAsync(
                    currentUserId,
                    credentialForm.ServiceName,
                    credentialForm.Username,
                    credentialForm.Password,
                    credentialForm.Comment);
            }
            else
            {
                // Update existing
                await CredentialService.UpdateCredentialAsync(
                    editingCredential.Id,
                    currentUserId,
                    credentialForm.ServiceName,
                    credentialForm.Username,
                    credentialForm.Password,
                    credentialForm.Comment);
            }

            await LoadCredentials();
            CloseModal();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to save credential");
            modalErrorMessage = "Failed to save credential. Please try again.";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task ConfirmDelete(StoredCredential credential)
    {
        if (currentUserId == null) return;

        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            $"Are you sure you want to delete the credential for '{SanitizationService.HtmlDecode(credential.ServiceName)}'?");

        if (confirmed)
        {
            await CredentialService.DeleteCredentialAsync(credential.Id, currentUserId);
            revealedPasswords.Remove(credential.Id);
            await LoadCredentials();
        }
    }

    private void RevealPassword(int credentialId)
    {
        revealedPasswords.Add(credentialId);
    }

    private void HidePassword(int credentialId)
    {
        revealedPasswords.Remove(credentialId);
    }

    private class CredentialFormModel
    {
        [Required]
        [StringLength(200)]
        public string ServiceName { get; set; } = string.Empty;

        [Required]
        [StringLength(200)]
        public string Username { get; set; } = string.Empty;

        [StringLength(1000)]
        public string Password { get; set; } = string.Empty;

        [StringLength(1000)]
        public string? Comment { get; set; }
    }
}
